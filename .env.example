# Pharmiperia — environment variables
# Copy to .env.local for local development. Never commit real secrets.

# ── Site (single switch for production domain — pharm.lv) ────────────────────
# All URLs, canonical, sitemap, emails derive from these. No domain hardcodes in code.
NEXT_PUBLIC_SITE_URL=https://pharm.lv
# SITE_URL=https://pharm.lv
# SUPPORT_EMAIL=support@pharm.lv
# INFO_EMAIL=info@pharm.lv
# ORDERS_EMAIL=orders@pharm.lv

# ── Supabase (required) ──────────────────────────────────────────────────────
# Production MUST use EU region (e.g. Frankfurt eu-central-1) — GDPR Phase 1 §7
# NEXT_PUBLIC_SUPABASE_REGION=EU (Frankfurt, eu-central-1)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Supabase CLI (remote type generation: pnpm db:types:remote) ──────────────
# SUPABASE_PROJECT_ID=your-project-ref
# SUPABASE_ACCESS_TOKEN=sbp_...

# ── Stripe (required for checkout) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Stripe webhook (required for payment confirmation — ADR-0005) ────────────
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Tax / PVN 21% (Phase 1 task 12 — ADR-0008) ───────────────────────
# Enable Stripe Tax in Dashboard → Settings → Tax (register Latvia LV, 21%).
# Catalog prices are tax-inclusive. Set to false only for local dev without Tax.
# STRIPE_TAX_ENABLED=false

# ── AI features (Phase 1 task 19, ADR-0013 — disabled until explicitly enabled) ─
# Recommendations OFF by default until Phase 3. Chat OFF by default in Phase 1.
# Both require OPENAI_API_KEY on server; UI uses NEXT_PUBLIC_* flags.
# OPENAI_API_KEY=sk-...
# NEXT_PUBLIC_AI_RECOMMENDATIONS_ENABLED=false
# NEXT_PUBLIC_AI_CHAT_ENABLED=false
# AI_DAILY_REQUEST_CAP=100
# AI_MAX_INPUT_CHARS=2000
# AI_MAX_CHAT_MESSAGES=20
# AI_MAX_OUTPUT_TOKENS=500
# AI_BUDGET_ENABLED=true

# ── Monitoring (Phase 1 task 20, ADR-0014) ─────────────────────────────────
# Uptime: GET https://pharm.lv/api/health every 1–5 min (expect 200).
# Deep check (Supabase): GET /api/health?deep=1&token=<MONITORING_HEALTH_TOKEN>
# MONITORING_HEALTH_TOKEN=...
#
# Ops checklist (Dashboards, not env): Vercel spend limits · Supabase usage alerts
# · Stripe billing/webhook alerts · Sentry alerts on commerce.checkout + monitoring.budget

# ── Email — order confirmation (Phase 1 task 13, Resend) ───────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=Pharmiperia <orders@pharm.lv>
# EMAIL_ENABLED=false

# ── Email — Supabase Auth SMTP (Phase 1 task 14, Resend) ─────────────────────
# Remote: Supabase Dashboard → Authentication → SMTP Settings
#   Host smtp.resend.com · Port 587 · User resend · Pass <RESEND_API_KEY>
#   Sender: noreply@pharm.lv (verify domain in Resend first)
# Local supabase/config.toml [auth.email.smtp] uses the same vars when enabled.
# AUTH_EMAIL_ADDRESS=noreply@pharm.lv
# AUTH_EMAIL_FROM=Pharmiperia <noreply@pharm.lv>

# ── Observability — Sentry (Phase 1 task 16, ADR-0010) ───────────────────────
# SDK initializes only when SENTRY_DSN or NEXT_PUBLIC_SENTRY_DSN is set.
# Set SENTRY_ENABLED=false to disable reporting without removing DSN.
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ORG=pharmiperia
# SENTRY_PROJECT=storefront
# SENTRY_ENVIRONMENT=production
# SENTRY_ENABLED=true
# SENTRY_AUTH_TOKEN=sntrys_...  # source maps upload at build (CI only)
#
# Sentry alert (Dashboard → Alerts): filter tag commerce.checkout=true for checkout failures.

# ── Rate limiting (Phase 1 task 17, ADR-0011) ────────────────────────────────
# Production: Upstash Redis REST API (https://console.upstash.com).
# Without Upstash, in-memory fallback applies (dev/CI only — not multi-instance safe).
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# RATE_LIMIT_ENABLED=true

# ── CAPTCHA — Cloudflare Turnstile (Phase 1 task 18, ADR-0012) ─────────────
# Widget shows on login/sign-up when site key is set. Verify server-side with secret.
# Test keys (always pass): site 1x00000000000000000000AA · secret 1x0000000000000000000000000000000AA
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# CAPTCHA_ENABLED=true

# ── E2E — Playwright (Phase 1 task 21, ADR-0015) ───────────────────────────
# Smoke checkout runs only when E2E_ENABLED=true and Supabase + Stripe test keys are set.
# CI skips e2e by default (no secrets). Local: pnpm test:e2e:install && pnpm test:e2e
# E2E_ENABLED=false
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# ── Production validation (Phase 1 task 22, ADR-0016) ────────────────────────
# pnpm validate:production — static gates + tsc + build (CI-safe placeholders).
# VALIDATE_RUN_BUILD=false  # skip next build for faster local check
# VALIDATE_RUN_TYPECHECK=false