# Pharmiperia — environment variables
# Copy to .env.local for local development. Never commit real secrets.

# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Supabase CLI (remote type generation: pnpm db:types:remote) ──────────────
# SUPABASE_PROJECT_ID=your-project-ref
# SUPABASE_ACCESS_TOKEN=sbp_...

# ── Stripe (required for checkout) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Stripe webhook (required for payment confirmation — ADR-0005) ────────────
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Tax / PVN 21% (Phase 1 task 12 — ADR-0008) ───────────────────────
# Enable Stripe Tax in Dashboard → Settings → Tax (register Latvia LV, 21%).
# Catalog prices are tax-inclusive. Set to false only for local dev without Tax.
# STRIPE_TAX_ENABLED=false

# ── AI features (optional — disabled until Phase 3) ────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Email (Phase 1 task 13 — order confirmation via Resend) ─────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=Pharmiperia <orders@pharmiperia.lv>
# NEXT_PUBLIC_SITE_URL=https://pharmiperia.lv
# EMAIL_ENABLED=false

# ── Observability (Phase 1 task 16) ──────────────────────────────────────────
# SENTRY_DSN=https://...
# SENTRY_AUTH_TOKEN=...