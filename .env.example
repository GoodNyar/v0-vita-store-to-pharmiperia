# Pharmiperia — environment variables
# Copy to .env.local for local development. Never commit real secrets.

# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe (required for checkout) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Stripe webhook (required in production — Phase 1 task 5) ───────────────────
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI features (optional — disabled until Phase 3) ────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Email (Phase 1 task 13–14) ─────────────────────────────────────────────────
# RESEND_API_KEY=re_...

# ── Observability (Phase 1 task 16) ──────────────────────────────────────────
# SENTRY_DSN=https://...
# SENTRY_AUTH_TOKEN=...